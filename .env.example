# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/reviveme_db"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=30d

# Google Sign-In
# Use the Web OAuth client ID. Add more IDs as comma-separated values if needed.
GOOGLE_CLIENT_IDS=your_google_web_client_id.apps.googleusercontent.com

# Shared secret for the Google Play RTDN webhook (?token=... on the push
# subscription URL) — generate any long random string and use the same
# value in your Pub/Sub push subscription config. See src/routes/googlePlayWebhook.js.
GOOGLE_PLAY_WEBHOOK_SECRET=

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
# For production use SendGrid / Mailgun / AWS SES etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="ReviveSpring <your_email@gmail.com>"

# Optional fallback instead of SMTP:
# RESEND_API_KEY=re_your_api_key
# RESEND_FROM="ReviveSpring <noreply@your-verified-domain.com>"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of web origins allowed to call this API with credentials.
# The mobile app does NOT need to be listed here — native HTTP requests don't
# send an Origin header, so they're never subject to CORS in the first place.
# If this is left unset, the server falls back to allowing all origins (and
# logs a warning) so you don't get locked out before configuring it.
ALLOWED_ORIGINS=http://localhost:5173,https://revivespring.com,https://www.revivespring.com,https://revivespring.onrender.com

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# OpenAI AI Companion
# Never put this key in mobile or web frontend code.
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-5.4
# Optional: low, medium, or high when supported by the selected model.
OPENAI_REASONING_EFFORT=medium
