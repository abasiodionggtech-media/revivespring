generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ─────────────────────────────────────────────────────
model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  passwordHash        String
  fullName            String?   @map("full_name")
  authProvider        String?   @map("auth_provider")
  googleSub           String?   @unique @map("google_sub")
  profileImageUrl     String?   @map("profile_image_url")
  role                String    @default("user")      // "user" | "admin"
  subscriptionStatus  String    @default("free")
  salvationDate       String?
  salvationPrayedAt   DateTime?                        // when they prayed salvation prayer
  testimony           String?
  language            String    @default("en")
  bibleVersion        String    @default("NIV") @map("bible_version")
  timezone            String    @default("UTC")        // for daily email timing
  registeredHour      Int       @default(8)            // legacy fallback hour
  reminderHour        Int       @default(9)  @map("reminder_hour")
  reminderMinute      Int       @default(0)  @map("reminder_minute")
  dailyEmailEnabled   Boolean   @default(true)         // opt-in/out of daily prayer emails
  pushNotificationsEnabled Boolean @default(true) @map("push_notifications_enabled")
  lastDailyEmailAt    DateTime?                        // last time daily email was sent
  isEmailVerified     Boolean   @default(false)
  isDisabled          Boolean   @default(false)
  otpCode             String?
  otpExpiresAt        DateTime?
  onboardingData      Json?     @map("onboarding_data")
  createdAt           DateTime  @default(now())
  prayers             Prayer[]
  journals   JournalEntry[]
  dailyGoals DailyGoal[]
  analytics  Analytics?
  notifications Notification[]
  supportTickets SupportTicket[]
  accountSessions AccountSession[]
  moodLogs MoodLog[]
  challengeEnrollments ChallengeEnrollment[]
  fasts Fast[]
  readingPlanProgress ReadingPlanProgress[]
  userMilestones UserMilestone[]
  memoryCardProgress MemoryCardProgress[]
  weeklyReviews WeeklyReview[]
  prayerRequests PrayerRequest[]
  prayerRequestPrays PrayerRequestPray[]
  testimonies Testimony[]
  testimonyReactions TestimonyReaction[]
  accountabilityInvites AccountabilityInvite[]
  partnershipsAsA AccountabilityPartnership[] @relation("PartnerA")
  partnershipsAsB AccountabilityPartnership[] @relation("PartnerB")
  prayerGroupMemberships PrayerGroupMembership[]
  mentorProfile MentorProfile?
  mentorshipsAsMentor MentorshipMatch[] @relation("MentorMatches")
  mentorshipsAsMentee MentorshipMatch[] @relation("MenteeMatches")

  @@map("users")
}

// ─── Mood Check-In (Daily) ──────────────────────────────────────
model MoodLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  mood      String
  note      String?
  date      String                              // YYYY-MM-DD, one check-in per user per day
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("mood_logs")
}

// ─── Prayer ───────────────────────────────────────────────────
model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String   @default("general")
  title     String
  body      String
  metadata  Json?
  readAt    DateTime? @map("read_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@map("notifications")
}

model SupportTicket {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  subject     String   @default("Customer care message")
  status      String   @default("open")
  priority    String   @default("normal")
  messages    Json     @default("[]")
  lastReplyAt DateTime? @map("last_reply_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, updatedAt])
  @@map("support_tickets")
}

model AccountSession {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  client      String
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, client])
  @@index([userId, lastSeenAt])
  @@map("account_sessions")
}

model Prayer {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  mood           String
  encouragement  String?
  bibleVerse     String?  @map("bible_verse")
  bibleReference String?  @map("bible_reference")
  prayerText     String   @map("prayer_text")
  actionStep     String?  @map("action_step")
  language       String   @default("en")
  isSaved        Boolean  @default(false) @map("is_saved")
  isAnswered     Boolean  @default(false) @map("is_answered")
  testimony      String?
  answeredAt     DateTime? @map("answered_at")
  createdDate    String?  @map("created_date")
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("prayers")
}

// ─── Prayer Library (admin-managed content) ───────────────────
model PrayerLibraryItem {
  id          String   @id @default(uuid())
  category    String                              // "morning" | "anxiety" | "healing" | "financial" | etc.
  titleEn     String   @map("title_en")
  titleFr     String?  @map("title_fr")
  verseEn     String?  @map("verse_en")
  verseFr     String?  @map("verse_fr")
  verseRef    String?  @map("verse_ref")
  prayerEn    String   @map("prayer_en")
  prayerFr    String?  @map("prayer_fr")
  actionEn    String?  @map("action_en")
  actionFr    String?  @map("action_fr")
  isPremium   Boolean  @default(false) @map("is_premium")
  isVisible   Boolean  @default(true)  @map("is_visible")
  sortOrder   Int      @default(0)     @map("sort_order")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("prayer_library")
}

// Daily goals configured by admins and assigned to each user on first visit.
model DailyGoalTemplate {
  id              String   @id @default(uuid())
  titleEn         String   @map("title_en")
  titleFr         String?  @map("title_fr")
  kind            String   @default("reflection") // "scripture" | "prayer" | "reflection" | "action"
  contentEn       String?  @map("content_en")
  contentFr       String?  @map("content_fr")
  durationSeconds Int      @default(10) @map("duration_seconds")
  isActive        Boolean  @default(true) @map("is_active")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  dailyGoals      DailyGoal[]

  @@map("daily_goal_templates")
}

// ─── Daily Verse (admin-managed) ──────────────────────────────
model DailyVerse {
  id        String   @id @default(uuid())
  verseEn   String   @map("verse_en")               // NIV wording (default translation)
  verseFr   String?  @map("verse_fr")
  verseKjv  String?  @map("verse_kjv")
  verseNlt  String?  @map("verse_nlt")
  verseEsv  String?  @map("verse_esv")
  reference String
  activeOn  String?  @map("active_on")            // "YYYY-MM-DD" or null for default
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("daily_verses")
}

// ─── Prophetic Declarations (admin-managed) ───────────────────
model Declaration {
  id        String   @id @default(uuid())
  textEn    String   @map("text_en")
  textFr    String?  @map("text_fr")
  category  String   @default("identity")            // "identity" | "healing" | "provision" | "purpose" | etc.
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("declarations")
}

// ─── 30-Day Prayer Challenges (admin-managed content + progress) ──
model Challenge {
  id            String   @id @default(uuid())
  titleEn       String   @map("title_en")
  titleFr       String?  @map("title_fr")
  descriptionEn String?  @map("description_en")
  descriptionFr String?  @map("description_fr")
  durationDays  Int      @default(30) @map("duration_days")
  category      String   @default("general")
  isActive      Boolean  @default(true) @map("is_active")
  sortOrder     Int      @default(0) @map("sort_order")
  eventId       String?  @map("event_id") // optional — links this challenge to a Seasonal Event
  createdAt     DateTime @default(now())

  enrollments ChallengeEnrollment[]

  @@map("challenges")
}

model ChallengeEnrollment {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  challengeId       String    @map("challenge_id")
  startedAt         DateTime  @default(now()) @map("started_at")
  completedDays     Json      @default("[]") @map("completed_days") // array of day numbers, e.g. [1,2,3]
  lastCompletedDate String?   @map("last_completed_date")           // YYYY-MM-DD, one check-in per day
  finishedAt        DateTime? @map("finished_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@map("challenge_enrollments")
}

// ─── Fasting Tracker ────────────────────────────────────────────
model Fast {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  fastType  String    @map("fast_type") // 'water' | 'daniel' | 'partial' | 'full' | 'custom'
  goalHours Int       @default(24) @map("goal_hours")
  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")
  status    String    @default("active") // 'active' | 'completed' | 'broken'
  notes     String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("fasts")
}

// ─── Bible Reading Plan (admin-managed content + progress) ─────
model ReadingPlan {
  id            String   @id @default(uuid())
  titleEn       String   @map("title_en")
  titleFr       String?  @map("title_fr")
  descriptionEn String?  @map("description_en")
  durationDays  Int      @default(7) @map("duration_days")
  days          Json     // [{ "day": 1, "referenceEn": "Genesis 1-3", "titleEn": "Creation" }, ...]
  isActive      Boolean  @default(true) @map("is_active")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now())

  progress ReadingPlanProgress[]

  @@map("reading_plans")
}

model ReadingPlanProgress {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  planId            String    @map("plan_id")
  startedAt         DateTime  @default(now()) @map("started_at")
  completedDays     Json      @default("[]") @map("completed_days")
  lastCompletedDate String?   @map("last_completed_date")
  finishedAt        DateTime? @map("finished_at")

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan ReadingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([userId, planId])
  @@map("reading_plan_progress")
}

// ─── Faith Milestones & Badges ─────────────────────────────────
model Milestone {
  id            String  @id @default(uuid())
  key           String  @unique
  titleEn       String  @map("title_en")
  titleFr       String? @map("title_fr")
  descriptionEn String? @map("description_en")
  descriptionFr String? @map("description_fr")
  icon          String  @default("emoji_events")
  criteriaType  String  @map("criteria_type") // 'streak' | 'prayers_total' | 'goals_total' | 'journal_total' | 'fasts_total' | 'challenges_total' | 'reading_plans_total'
  criteriaValue Int     @map("criteria_value")
  sortOrder     Int     @default(0) @map("sort_order")
  isActive      Boolean @default(true) @map("is_active")

  achievedBy UserMilestone[]

  @@map("milestones")
}

model UserMilestone {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  milestoneId String   @map("milestone_id")
  achievedAt  DateTime @default(now()) @map("achieved_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@unique([userId, milestoneId])
  @@map("user_milestones")
}

// ─── Scripture Memory Cards ─────────────────────────────────────
model MemoryCard {
  id        String   @id @default(uuid())
  referenceEn String @map("reference_en")
  verseEn   String   @map("verse_en")
  verseFr   String?  @map("verse_fr")
  category  String   @default("general")
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now())

  progress MemoryCardProgress[]

  @@map("memory_cards")
}

model MemoryCardProgress {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  cardId            String    @map("card_id")
  addedAt           DateTime  @default(now()) @map("added_at")
  reviewCount       Int       @default(0) @map("review_count")
  lastReviewedDate  String?   @map("last_reviewed_date")
  quizAttempts      Int       @default(0) @map("quiz_attempts")
  quizPassedAt      DateTime? @map("quiz_passed_at")
  mastered          Boolean   @default(false)

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  card MemoryCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@map("memory_card_progress")
}

// ─── Worship Mode (admin-managed playlist) ─────────────────────
model WorshipTrack {
  id            String   @id @default(uuid())
  titleEn       String   @map("title_en")
  artist        String?
  platform      String   @default("youtube") // 'youtube' | 'spotify' | 'audio_url'
  url           String
  category      String   @default("worship") // 'praise' | 'worship' | 'instrumental'
  durationLabel String?  @map("duration_label")
  isActive      Boolean  @default(true) @map("is_active")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now())

  @@map("worship_tracks")
}

// ─── Weekly Spiritual Review ────────────────────────────────────
model WeeklyReview {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  weekStartDate  String    @map("week_start_date") // YYYY-MM-DD (Monday of that week)
  aiSummary      String?   @map("ai_summary")
  userReflection String?   @map("user_reflection")
  stats          Json?
  generatedAt    DateTime? @map("generated_at")
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStartDate])
  @@map("weekly_reviews")
}

// ─── Prayer Chain ────────────────────────────────────────────
model PrayerRequest {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  text        String
  isAnonymous Boolean  @default(false) @map("is_anonymous")
  category    String   @default("general")
  status      String   @default("active") // 'active' | 'answered'
  prayerCount Int      @default(0) @map("prayer_count")
  groupId     String?  @map("group_id") // optional — set when posted inside a Prayer Group
  createdAt   DateTime @default(now())

  user  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  group PrayerGroup?        @relation(fields: [groupId], references: [id], onDelete: SetNull)
  prays PrayerRequestPray[]

  @@map("prayer_requests")
}

model PrayerRequestPray {
  id        String   @id @default(uuid())
  requestId String   @map("request_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now())

  request PrayerRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([requestId, userId])
  @@map("prayer_request_prays")
}

// ─── Testimony Feed ──────────────────────────────────────────
model Testimony {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  title       String
  content     String
  isAnonymous Boolean  @default(false) @map("is_anonymous")
  createdAt   DateTime @default(now())

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions TestimonyReaction[]

  @@map("testimonies")
}

model TestimonyReaction {
  id          String   @id @default(uuid())
  testimonyId String   @map("testimony_id")
  userId      String   @map("user_id")
  createdAt   DateTime @default(now())

  testimony Testimony @relation(fields: [testimonyId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([testimonyId, userId])
  @@map("testimony_reactions")
}

// ─── Accountability Partner ──────────────────────────────────
model AccountabilityInvite {
  id         String    @id @default(uuid())
  inviterId  String    @map("inviter_id")
  inviteCode String    @unique @map("invite_code")
  status     String    @default("pending") // 'pending' | 'accepted' | 'expired'
  acceptedBy String?   @map("accepted_by")
  createdAt  DateTime  @default(now())
  acceptedAt DateTime? @map("accepted_at")

  inviter User @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@map("accountability_invites")
}

model AccountabilityPartnership {
  id        String   @id @default(uuid())
  userAId   String   @map("user_a_id")
  userBId   String   @map("user_b_id")
  createdAt DateTime @default(now())

  userA User @relation("PartnerA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("PartnerB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@map("accountability_partnerships")
}

model AccountabilityNudge {
  id        String   @id @default(uuid())
  fromUserId String  @map("from_user_id")
  toUserId  String   @map("to_user_id")
  message   String?
  createdAt DateTime @default(now())

  @@map("accountability_nudges")
}

// ─── Prayer Groups (Premium) ──────────────────────────────────
model PrayerGroup {
  id            String   @id @default(uuid())
  name          String
  description   String?
  createdByUserId String @map("created_by_user_id")
  isPublic      Boolean  @default(true) @map("is_public")
  joinCode      String   @unique @map("join_code")
  createdAt     DateTime @default(now())

  members  PrayerGroupMembership[]
  requests PrayerRequest[]

  @@map("prayer_groups")
}

model PrayerGroupMembership {
  id       String   @id @default(uuid())
  groupId  String   @map("group_id")
  userId   String   @map("user_id")
  role     String   @default("member") // 'member' | 'admin'
  joinedAt DateTime @default(now()) @map("joined_at")

  group PrayerGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("prayer_group_memberships")
}

// ─── Spiritual Mentorship Matching (Premium) ─────────────────
model MentorProfile {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  bio         String?
  focusAreas  String[] @default([]) @map("focus_areas")
  isAvailable Boolean  @default(true) @map("is_available")
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mentor_profiles")
}

model MentorshipMatch {
  id            String    @id @default(uuid())
  mentorUserId  String    @map("mentor_user_id")
  menteeUserId  String    @map("mentee_user_id")
  status        String    @default("pending") // 'pending' | 'active' | 'completed' | 'declined'
  checkIns      Json      @default("[]") @map("check_ins") // [{date, note, byUserId}]
  startedAt     DateTime? @map("started_at")
  createdAt     DateTime  @default(now())

  mentor User @relation("MentorMatches", fields: [mentorUserId], references: [id], onDelete: Cascade)
  mentee User @relation("MenteeMatches", fields: [menteeUserId], references: [id], onDelete: Cascade)

  @@unique([mentorUserId, menteeUserId])
  @@map("mentorship_matches")
}

// ─── Seasonal Events ──────────────────────────────────────────
model SeasonalEvent {
  id            String   @id @default(uuid())
  key           String   @unique
  titleEn       String   @map("title_en")
  titleFr       String?  @map("title_fr")
  descriptionEn String?  @map("description_en")
  icon          String   @default("celebration")
  startDate     String   @map("start_date") // YYYY-MM-DD
  endDate       String   @map("end_date")   // YYYY-MM-DD
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now())

  @@map("seasonal_events")
}

// ─── Mental Health Content (admin-managed) ────────────────────
model MentalHealthContent {
  id          String   @id @default(uuid())
  category    String                              // "anxiety"|"depression"|"stress"|"sleep"|"grief"|"selfworth"|"affirmation"
  titleEn     String   @map("title_en")
  titleFr     String?  @map("title_fr")
  contentEn   String   @map("content_en")
  contentFr   String?  @map("content_fr")
  audioUrl    String?  @map("audio_url")
  isPremium   Boolean  @default(true)  @map("is_premium")
  isVisible   Boolean  @default(true)  @map("is_visible")
  sortOrder   Int      @default(0)     @map("sort_order")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("mental_health_content")
}

// ─── Salvation Content (admin-managed) ────────────────────────
model SalvationContent {
  id          String   @id @default(uuid())
  key         String   @unique                    // "intro"|"prayer"|"verses"|"guide"
  contentEn   String   @map("content_en")
  contentFr   String?  @map("content_fr")
  updatedAt   DateTime @updatedAt

  @@map("salvation_content")
}

// ─── App Settings (admin-managed key-value) ───────────────────
model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

// ─── AI Chat Conversations ────────────────────────────────────
model AiConversation {
  id        String    @id @default(uuid())
  sessionId String    @map("session_id")          // anonymous or user-based session
  userEmail String?   @map("user_email")
  messages  Json      @default("[]")              // [{role,content,timestamp}]
  language  String    @default("en")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("ai_conversations")
}

// ─── AI Knowledge Base (admin-managed FAQs) ──────────────────
model AiKnowledgeBase {
  id        String   @id @default(uuid())
  question  String
  answerEn  String   @map("answer_en")
  answerFr  String?  @map("answer_fr")
  category  String   @default("general")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_knowledge_base")
}

// ─── Journal Entry ────────────────────────────────────────────
model JournalEntry {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  title       String
  content     String
  mood        String?
  status      String   @default("active")
  language    String   @default("en")
  tags        String[] @default([])
  aiInterpretation String? @map("ai_interpretation") // used by the AI Dream/Vision Journal feature
  createdDate String?  @map("created_date")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("journal_entries")
}

// ─── Daily Goal ───────────────────────────────────────────────
model DailyGoal {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  templateId      String?  @map("template_id")
  text            String
  kind            String   @default("reflection")
  content         String?
  durationSeconds Int      @default(10) @map("duration_seconds")
  completed       Boolean  @default(false)
  completedAt     DateTime? @map("completed_at")
  date            String
  language        String   @default("en")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  template DailyGoalTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@unique([userId, date, templateId])
  @@map("daily_goals")
}

// ─── Analytics ────────────────────────────────────────────────
model Analytics {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  totalPrayers    Int      @default(0) @map("total_prayers")
  answeredPrayers Int      @default(0) @map("answered_prayers")
  currentStreak   Int      @default(0) @map("current_streak")
  longestStreak   Int      @default(0) @map("longest_streak")
  visitCount      Int      @default(0) @map("visit_count")
  lastActiveDate  String?  @map("last_active_date")
  gracePeriodUsed Boolean  @default(false) @map("grace_period_used")   // true once the current streak's 1-day grace has been spent
  graceUsedOnDate String?  @map("grace_used_on_date")                  // date the grace day covered, for notification/history purposes
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("analytics")
}
