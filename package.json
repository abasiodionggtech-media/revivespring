{
  "name": "reviveme-backend",
  "version": "1.0.0",
  "description": "ReviveMe Node.js REST API",
  "main": "src/index.js",
  "scripts": {
    "start": "node scripts/migrate.js && node src/index.js",
    "build": "npm run generate",
    "postinstall": "npm run generate",
    "dev": "nodemon src/index.js",
    "migrate": "npx prisma migrate dev",
    "migrate:deploy": "npx prisma migrate deploy",
    "generate": "npx prisma generate",
    "seed": "node src/config/seed.js",
    "reset:regular-users": "node scripts/reset-regular-users.js",
    "studio": "npx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "google-auth-library": "^9.15.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.14",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^5.14.0"
  }
}
